# Builder stage: compile nginx static from source
FROM debian:trixie-slim AS builder

# Install build dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    make \
    libpcre2-dev \
    zlib1g-dev \
    libssl-dev \
    ca-certificates \
    wget \
    pkg-config \
    && rm -rf /var/lib/apt/lists/*

# Download nginx mainline source
ENV NGINX_VERSION=1.27.0
RUN wget -qO- http://nginx.org/download/nginx-${NGINX_VERSION}.tar.gz | tar xz

# Build nginx with static linking
WORKDIR /nginx-${NGINX_VERSION}
RUN ./configure \
    --prefix=/etc/nginx \
    --sbin-path=/usr/sbin/nginx \
    --conf-path=/etc/nginx/nginx.conf \
    --pid-path=/var/run/nginx.pid \
    --lock-path=/var/run/nginx.lock \
    --error-log-path=/var/log/nginx/error.log \
    --http-log-path=/var/log/nginx/access.log \
    --with-stream \
    --with-http_gzip_static_module \
    --with-http_stub_status_module \
    --with-ld-opt="-static -static-libgcc -static-libstdc++" \
    && make -j$(nproc) \
    && make install DESTDIR=/tmp/nginx

# Create required files and directories
RUN mkdir -p /tmp/nginx/var/log/nginx /tmp/nginx/var/run/nginx /tmp/etc/nginx /tmp/var/www/html
RUN touch /tmp/etc/nginx/client_body_temp
RUN touch /tmp/nginx/var/run/nginx.pid
RUN touch /tmp/nginx/var/run/nginx.lock
RUN echo "<p>Hello</p>" > /tmp/var/www/html/index.html

# Runtime stage: use distroless static
FROM gcr.io/distroless/static-debian13:nonroot

# Copy nginx binary and configuration from builder
COPY --from=builder --chown=nonroot:nonroot /tmp/etc/nginx /etc/nginx
COPY --from=builder /tmp/nginx/usr/sbin/nginx /usr/sbin/nginx
COPY --from=builder /tmp/nginx/etc/nginx/nginx.conf /etc/nginx/nginx.conf
COPY --from=builder /tmp/nginx/etc/nginx/koi-utf /etc/nginx/koi-utf
COPY --from=builder /tmp/nginx/etc/nginx/koi-win /etc/nginx/koi-win
COPY --from=builder /tmp/nginx/etc/nginx/mime.types /etc/nginx/mime.types
COPY --from=builder /tmp/nginx/etc/nginx/scgi_params /etc/nginx/scgi_params
COPY --from=builder /tmp/nginx/etc/nginx/uwsgi_params /etc/nginx/uwsgi_params
COPY --from=builder /tmp/nginx/etc/nginx/win-utf /etc/nginx/win-utf
COPY --from=builder --chown=nonroot:nonroot /tmp/nginx/var/log/nginx /var/log/nginx
COPY --from=builder --chown=nonroot:nonroot /tmp/nginx/var/run/nginx /var/run/nginx
COPY --from=builder --chown=nonroot:nonroot /tmp/nginx/var/run/nginx.pid /var/run/nginx.pid
COPY --from=builder --chown=nonroot:nonroot /tmp/nginx/var/run/nginx.lock /var/run/nginx.lock
COPY --from=builder --chown=nonroot:nonroot /tmp/var/www/html /etc/nginx/html

# Expose HTTP and HTTPS ports
EXPOSE 80 443

USER nonroot:nonroot

# Start nginx
CMD ["/usr/sbin/nginx", "-g", "daemon off;"]
